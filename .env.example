# Copy to .env only for native backend development. Docker Compose defines safe local defaults.
CAPSTONE_ENVIRONMENT=development
CAPSTONE_DATABASE_URL=sqlite:///./data/capstone.db
CAPSTONE_DATA_ROOT=./data
CAPSTONE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Stage 4 AI enrichment. Keep deterministic for offline testing, or set gemini.
CAPSTONE_AI_PROVIDER=deterministic
CAPSTONE_GEMINI_API_KEY=
CAPSTONE_GEMINI_MODEL=gemini-2.5-flash-lite
