{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capstone.local/schemas/capstone-import-v1.schema.json",
  "title": "CAPSTONE Import Schema 1.0",
  "type": "object",
  "required": ["schema_version", "assets"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "profile": {
      "type": ["object", "null"],
      "properties": {
        "name": { "type": "string", "maxLength": 200 },
        "current_title": { "type": "string", "maxLength": 250 },
        "current_organisation": { "type": "string", "maxLength": 250 },
        "career_mission": { "type": "string", "maxLength": 10000 },
        "career_narrative": { "type": "string", "maxLength": 30000 }
      },
      "additionalProperties": true
    },
    "themes": { "type": "array", "items": { "$ref": "#/$defs/theme" } },
    "goals": { "type": "array", "items": { "$ref": "#/$defs/goal" } },
    "organisations": { "type": "array", "items": { "$ref": "#/$defs/organisation" } },
    "people": { "type": "array", "items": { "type": "object" } },
    "assets": { "type": "array", "items": { "$ref": "#/$defs/asset" } }
  },
  "$defs": {
    "theme": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "description": { "type": "string" }
      }
    },
    "goal": {
      "type": "object",
      "required": ["title", "horizon"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "horizon": { "enum": ["short_term", "medium_term", "long_term"] },
        "target_date": { "type": ["string", "null"], "format": "date" }
      }
    },
    "organisation": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "organisation_type": { "type": "string" },
        "website": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "asset": {
      "type": "object",
      "required": ["title", "category"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 300 },
        "description": { "type": "string" },
        "category": { "type": "string", "minLength": 1 },
        "subcategory": { "type": "string" },
        "start_date": { "type": ["string", "null"], "format": "date" },
        "end_date": { "type": ["string", "null"], "format": "date" },
        "date_precision": { "enum": ["day", "month", "year", "unknown"] },
        "status": { "enum": ["draft", "active", "archived"] },
        "impact_summary": { "type": "string" },
        "organisation_id": { "type": ["string", "null"], "format": "uuid" },
        "role": { "type": "string" },
        "visibility": { "enum": ["public", "professional"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "theme_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } }
      }
    }
  },
  "additionalProperties": true
}

